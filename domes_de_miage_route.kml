<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Alpinisme : Ascension des Dômes de Miage (Aller-Retour)</name>
    <description><![CDATA[
      <h1>Ascension des Dômes de Miage (3670m)</h1>
      <p>Itinéraire d'alpinisme classique en aller-retour depuis Les Contamines-Montjoie (Le Cugnon), avec descente en boucle par l'Aiguille de la Bérangère.</p>
      <p><b>Sommet :</b> Dômes de Miage, Sommet Ouest (3670m)</p>
      <p><b>Nuit conseillée :</b> Refuge des Conscrits (2602m)</p>
    ]]></description>

    <!-- Styles for Paths -->
    <Style id="ascentRouteStyle">
      <LineStyle>
        <color>ff8000ff</color> <!-- Warm Purple (abgr: ff8000ff) -->
        <width>4</width>
      </LineStyle>
    </Style>
    <Style id="descentRouteStyle">
      <LineStyle>
        <color>ffffaa00</color> <!-- Cool Blue/Cyan (abgr: ffffaa00) -->
        <width>4</width>
      </LineStyle>
    </Style>

    <!-- Styles for Icons -->
    <Style id="summitPlacemark">
      <IconStyle>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/triangle.png</href>
        </Icon>
      </IconStyle>
    </Style>
    <Style id="hutPlacemark">
      <IconStyle>
        <scale>1.1</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/homegardenbusiness.png</href>
        </Icon>
      </IconStyle>
    </Style>
    <Style id="villagePlacemark">
      <IconStyle>
        <scale>1.0</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/info.png</href>
        </Icon>
      </IconStyle>
    </Style>

    <!-- 1. Folder for Waypoints -->
    <Folder>
      <name>Points Clés de l'Itinéraire</name>
      <Placemark>
        <name>Le Cugnon (Les Contamines) (1180m)</name>
        <description>Départ de la course. Hameau du Cugnon aux Contamines-Montjoie (~1180m).</description>
        <styleUrl>#villagePlacemark</styleUrl>
        <Point>
          <coordinates>6.72808,45.81222,1180</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Refuge de Tré la Tête (1970m)</name>
        <description>Refuge chaleureux (1970m) perché au-dessus de la vallée de Tré la Tête.</description>
        <styleUrl>#hutPlacemark</styleUrl>
        <Point>
          <coordinates>6.73478,45.79175,1970</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Refuge des Conscrits (2602m)</name>
        <description>Refuge du CAF (2602m) niché au pied des Dômes de Miage.</description>
        <styleUrl>#hutPlacemark</styleUrl>
        <Point>
          <coordinates>6.766,45.7869,2602</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Aiguille de la Bérangère (3425m)</name>
        <description>Sommet rocheux et neigeux (3425m), fantastique belvédère de l'arête de Miage.</description>
        <styleUrl>#summitPlacemark</styleUrl>
        <Point>
          <coordinates>6.77879,45.80277,3425</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Dômes de Miage (Sommet W) (3670m)</name>
        <description>Sommet occidental des Dômes de Miage (3670m), point culminant de notre montée.</description>
        <styleUrl>#summitPlacemark</styleUrl>
        <Point>
          <coordinates>6.78979,45.81043,3670</coordinates>
        </Point>
      </Placemark>
    </Folder>

    <!-- 2. Folder for Trails -->
    <Folder>
      <name>Tracés de l'Itinéraire</name>
