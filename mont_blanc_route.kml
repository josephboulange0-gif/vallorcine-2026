<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Itinéraire Alpinisme : Trient - Aiguille du Tour - Le Tour</name>
    <description><![CDATA[
      <h1>Itinéraire Alpinisme : Traversée Trient → Aiguille du Tour → Le Tour</h1>
      <p>Itinéraire haute montagne précis reliant la Suisse à la France par le plateau glaciaire du Trient.</p>
      <p><b>Distance totale :</b> ~30 km (Itinéraire principal)</p>
      <p><b>Sommet :</b> Aiguille du Tour, sommet Sud (3542m)</p>
    ]]></description>

    <!-- Styles for Paths -->
    <Style id="mainRouteStyle">
      <LineStyle>
        <color>ffff0080</color> <!-- Purple (abgr: ffff0080) -->
        <width>4</width>
      </LineStyle>
    </Style>
    <Style id="descentRouteStyle">
      <LineStyle>
        <color>ff0000ff</color> <!-- Red (abgr: ff0000ff) -->
        <width>4</width>
      </LineStyle>
    </Style>

    <!-- Styles for Huts and Summits -->
    <Style id="summitPlacemark">
      <IconStyle>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/triangle.png</href>
        </Icon>
      </IconStyle>
    </Style>
    <Style id="hutPlacemark">
      <IconStyle>
        <scale>1.1</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/homegardenbusiness.png</href>
        </Icon>
      </IconStyle>
    </Style>
    <Style id="villagePlacemark">
      <IconStyle>
        <scale>1.0</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/info.png</href>
        </Icon>
      </IconStyle>
    </Style>

    <!-- 1. Folder for Waypoints -->
    <Folder>
      <name>Points Clés de l'Itinéraire</name>
      <Placemark>
        <name>Trient (Village) (1300m)</name>
        <description>Départ de la course. Village suisse dans la vallée du Trient (~1300m).</description>
        <styleUrl>#villagePlacemark</styleUrl>
        <Point>
          <coordinates>6.9953742,46.0559487,1300</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Col de la Forclaz (1527m)</name>
        <description>Col routier reliant Martigny à la vallée du Trient (1527m).</description>
        <styleUrl>#villagePlacemark</styleUrl>
        <Point>
          <coordinates>7.0011416,46.0579839,1527</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Chalet du Glacier (1583m)</name>
        <description>Buvette du Glacier du Trient (1583m), début de l'ascension.</description>
        <styleUrl>#hutPlacemark</styleUrl>
        <Point>
          <coordinates>7.0087355,46.0323212,1583</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Chalet des Grands (2113m)</name>
        <description>Chalet des Grands-Dessus (2113m), abri rustique du CAS Payerne.</description>
        <styleUrl>#hutPlacemark</styleUrl>
        <Point>
          <coordinates>7.0049483,46.0230257,2113</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Col des Grands (2635m)</name>
        <description>Col des Grands (2635m), passage vers le glacier du Trient.</description>
        <styleUrl>#villagePlacemark</styleUrl>
        <Point>
          <coordinates>7.0039,46.0135,2635</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Cabane du Trient (3170m)</name>
        <description>Cabane du Trient (3170m, CAS Diablerets) dominant le plateau glaciaire.</description>
        <styleUrl>#hutPlacemark</styleUrl>
        <Point>
          <coordinates>7.04364,45.99954,3170</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Aiguille du Tour (Sommet Sud) (3542m)</name>
        <description>Sommet Sud de l'Aiguille du Tour (3542m), point culminant de la course.</description>
        <styleUrl>#summitPlacemark</styleUrl>
        <Point>
          <coordinates>7.0100128,45.9945308,3542</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Refuge Albert 1er (2702m)</name>
        <description>Refuge Albert 1er (CAF, 2702m), surplombant le glacier du Tour.</description>
        <styleUrl>#hutPlacemark</styleUrl>
        <Point>
          <coordinates>6.98663,45.99675,2702</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Le Tour (Village) (1453m)</name>
        <description>Arrivée de la course côté France. Village du Tour (~1453m).</description>
        <styleUrl>#villagePlacemark</styleUrl>
        <Point>
          <coordinates>6.947,46.003,1453</coordinates>
        </Point>
      </Placemark>
    </Folder>

